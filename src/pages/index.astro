---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Hero from '../components/Hero';
import ProblemSection from '../components/ProblemSection';
import Services from '../components/Services';
import About from '../components/About';
import Blog from '../components/Blog';
import Contact from '../components/Contact';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const pageTitle = "KI Automatisierung Frankfurt – KI Agentur für Rhein-Main";
const pageDescription = "KI Automatisierung Agentur Frankfurt: Workflows, Chatbots und Prozessautomatisierung für Unternehmen in Frankfurt und dem Rhein-Main-Gebiet. Persönliche Beratung, schnelle Umsetzung, messbare Ergebnisse.";

const posts = (await getCollection('blog')).map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  readTime: p.data.readTime,
  author: p.data.author,
  date: p.data.date,
  image: p.data.image || "/placeholder.svg"
}));
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  image="/src/assets/ai-hero-image.jpg"
  type="website"
>
  <Navigation client:load />
  
  <main>
    <div id="hero">
      <Hero client:load />
    </div>
    
    <div id="problems">
      <ProblemSection client:load />
    </div>
    
    <div id="services">
      <Services client:load />
    </div>
    
    <!-- KI Automatisierung Frankfurt Section -->
    <section class="py-20 bg-gradient-to-b from-blue-400/5 via-purple-400/5 to-transparent">
      <div class="max-w-6xl mx-auto px-6">
        <div class="rounded-2xl border border-border/60 bg-gradient-to-br from-background/80 to-background/60 backdrop-blur-sm p-8 md:p-12 shadow-lg">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
            <div>
              <div class="inline-block px-3 py-1 rounded-full border border-blue-400/40 bg-blue-400/10 text-blue-500 text-sm font-medium mb-4">
                Frankfurt & Rhein-Main
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-4">KI Automatisierung Frankfurt</h2>
              <p class="text-lg text-muted-foreground mb-4">
                Als KI Automatisierung Agentur aus Frankfurt automatisieren wir wiederkehrende Prozesse in Unternehmen im Rhein-Main-Gebiet – von einfachen Workflows bis zu komplexen KI-Agenten.
              </p>
              <p class="text-muted-foreground mb-6">
                Typische Ergebnisse für Frankfurter Unternehmen: 20–50 % weniger manuelle Arbeit, schnellere Reaktionszeiten im Support, höhere Datenqualität – ohne zusätzliches Personal. Mit n8n, Make und OpenClaw bauen wir Lösungen, die sofort messbar wirken.
              </p>
              <ul class="space-y-2 text-muted-foreground mb-8">
                <li class="flex items-center gap-2"><span class="text-blue-500 font-bold">→</span> Support-Chatbots & automatische Ticket-Vorsortierung</li>
                <li class="flex items-center gap-2"><span class="text-blue-500 font-bold">→</span> Dokumentenverarbeitung (Rechnungen, Verträge, Formulare)</li>
                <li class="flex items-center gap-2"><span class="text-blue-500 font-bold">→</span> E-Mail- & Lead-Qualifizierungsworkflows</li>
                <li class="flex items-center gap-2"><span class="text-blue-500 font-bold">→</span> Marketing-Automation & Content-Erstellung</li>
              </ul>
              <a href="/ki-automatisierung" class="inline-flex items-center justify-center px-6 py-3 rounded-[5px] bg-gradient-to-r from-blue-500 to-purple-500 text-white hover:from-blue-600 hover:to-purple-600 transition-colors">
                KI Automatisierung Frankfurt →
              </a>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="p-5 rounded-xl border border-border bg-white/60 dark:bg-white/5">
                <div class="text-3xl font-bold text-blue-500 mb-1">20–50%</div>
                <div class="text-sm text-muted-foreground">weniger manuelle Arbeit in Routineaufgaben</div>
              </div>
              <div class="p-5 rounded-xl border border-border bg-white/60 dark:bg-white/5">
                <div class="text-3xl font-bold text-purple-500 mb-1">1–2 Wo.</div>
                <div class="text-sm text-muted-foreground">bis zum ersten lauffähigen Prototyp</div>
              </div>
              <div class="p-5 rounded-xl border border-border bg-white/60 dark:bg-white/5">
                <div class="text-3xl font-bold text-blue-500 mb-1">400+</div>
                <div class="text-sm text-muted-foreground">Integrationen mit n8n & Make</div>
              </div>
              <div class="p-5 rounded-xl border border-border bg-white/60 dark:bg-white/5">
                <div class="text-3xl font-bold text-purple-500 mb-1">24/7</div>
                <div class="text-sm text-muted-foreground">automatisierte Prozesse ohne manuelle Eingriffe</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div id="about">
      <About client:load />
    </div>
    
    <div id="blog">
      <Blog client:load posts={posts} limit={3} showViewAll={true} />
    </div>
    
    <div id="contact">
      <Contact client:load />
    </div>
  </main>

  <Footer />

  <!-- Additional Structured Data for Homepage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "KI Frankfurt",
    "url": "https://frankfurt-ai.de",
    "description": pageDescription,
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://frankfurt-ai.de/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "KI Automatisierung Frankfurt",
    "serviceType": "KI-Automatisierung",
    "provider": {
      "@type": "Organization",
      "name": "Vivid AI Lab",
      "url": "https://frankfurt-ai.de",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Frankfurt am Main",
        "addressRegion": "Hessen",
        "addressCountry": "DE"
      }
    },
    "areaServed": [
      { "@type": "City", "name": "Frankfurt am Main" },
      { "@type": "AdministrativeArea", "name": "Rhein-Main-Gebiet" }
    ],
    "description": "KI Automatisierung Agentur Frankfurt: Workflows, Chatbots und Prozessautomatisierung für Unternehmen in Frankfurt und dem Rhein-Main-Gebiet.",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "KI-Automatisierungslösungen Frankfurt",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Workflow-Automatisierung Frankfurt" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Support-Chatbots Frankfurt" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dokumentenverarbeitung Frankfurt" } }
      ]
    }
  })} />
</Layout>
